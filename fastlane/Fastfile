# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:android)

platform :android do
  def screenshot_emulator_serial
    serial_from_env = ENV['ANDROID_SERIAL']
    return serial_from_env unless serial_from_env.to_s.empty?

    devices_output = sh('adb devices', log: false)
    devices_output.each_line do |line|
      normalized = line.strip
      next if normalized.empty? || normalized.start_with?('List of devices')

      serial, state = normalized.split(/\s+/)
      next unless state == 'device' && serial.start_with?('emulator-')

      return serial
    end

    nil
  end

  def set_moscow_emulator_location
    serial = screenshot_emulator_serial
    if serial.nil?
      UI.important('Эмулятор не найден, шаг установки геолокации Москвы пропущен')
      return
    end

    UI.message("Устанавливаем геолокацию Москва для #{serial}")
    sh("adb -s #{serial} emu geo fix 37.6173 55.7558")
  rescue => e
    UI.important("Не удалось установить геолокацию Москва: #{e.message}")
  end

  desc "Runs all the tests"
  lane :test do
    gradle(task: "test")
  end

  desc "Submit a new Beta Build to Crashlytics Beta"
  lane :beta do
    gradle(task: "clean assembleRelease")
    crashlytics

    # sh "your_script.sh"
    # You can also use other beta testing services here
  end

  desc "Deploy a new version to the Google Play"
  lane :deploy do
    gradle(task: "clean assembleRelease")
    upload_to_play_store
  end

  desc "Создание скриншотов"
  lane :screenshots do
    set_moscow_emulator_location
    capture_android_screenshots(
      locales: ['ru-RU'],
      clear_previous_screenshots: true,
      app_apk_path: File.expand_path('../app/build/outputs/apk/debug/app-debug.apk', __dir__),
      tests_apk_path: File.expand_path('../screenshot-tests/build/outputs/apk/debug/screenshot-tests-debug.apk', __dir__)
    )
  end

end
